// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

/// @seed = "tsx prisma/seed.ts"

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  COUNSELOR
  ADMIN
}

enum CounselorApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssignmentMode {
  ALL_COUNSELORS
  SELECTED_COUNSELORS
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(USER)
  counselorApprovalStatus CounselorApprovalStatus @default(PENDING)
  approvedAt DateTime?
  approvedByUserId String?
  rejectionReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // User preferences
  preferences UserPreferences?

  // Bookings made by this user
  bookings Booking[]

  // AI conversations
  aiConversations AIConversation[]

  // Login tokens
  loginTokens LoginToken[]

  approvedBy User? @relation("CounselorApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvedCounselors User[] @relation("CounselorApprover")
  createdBookingSettings BookingAssignmentSetting[] @relation("BookingAssignmentCreatedBy")

  @@map("users")
}

model LoginToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_tokens")
}

model UserPreferences {
  id                    String   @id @default(cuid())
  userId                String   @unique
  preferredCounselorId  String?
  preferredTimeSlots    String[] // JSON array of preferred time slots
  timezone              String   @default("UTC")
  notificationSettings  Json     @default("{}")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredCounselor Counselor? @relation(fields: [preferredCounselorId], references: [id])

  @@map("user_preferences")
}

model Counselor {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  specialties String[] // Areas of expertise
  bio         String?
  avatar      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Counselor availability
  availability CounselorAvailability[]

  // Bookings with this counselor
  bookings Booking[]
  assignmentSettings BookingAssignmentCounselor[]
  sessionRecords SessionRecord[]

  // Users who prefer this counselor
  preferredByUsers UserPreferences[]

  @@map("counselors")
}

model BookingAssignmentSetting {
  id             String         @id @default(cuid())
  mode           AssignmentMode @default(ALL_COUNSELORS)
  isActive       Boolean        @default(true)
  createdById    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  createdBy      User?                          @relation("BookingAssignmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  selectedCounselors BookingAssignmentCounselor[]

  @@map("booking_assignment_settings")
}

model BookingAssignmentCounselor {
  id          String @id @default(cuid())
  settingId   String
  counselorId String
  createdAt   DateTime @default(now())

  setting     BookingAssignmentSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)
  counselor   Counselor @relation(fields: [counselorId], references: [id], onDelete: Cascade)

  @@unique([settingId, counselorId])
  @@map("booking_assignment_counselors")
}

model CounselorAvailability {
  id          String   @id @default(cuid())
  counselorId String
  dayOfWeek   Int      // 0-6 (Sunday-Saturday)
  startTime   String   // HH:MM format
  endTime     String   // HH:MM format
  timezone    String   @default("UTC")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  counselor Counselor @relation(fields: [counselorId], references: [id], onDelete: Cascade)

  @@map("counselor_availability")
}

model Booking {
  id                String        @id @default(cuid())
  userId            String
  counselorId       String
  scheduledAt       DateTime
  duration          Int           @default(60) // Duration in minutes
  status            BookingStatus @default(SCHEDULED)
  meetingLink       String?       // Video conference link
  meetingId         String?       // Meeting room identifier
  notes             String?       // User notes or AI-generated summary
  aiConversationId  String?       // Reference to AI conversation that led to booking
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  counselor Counselor @relation(fields: [counselorId], references: [id], onDelete: Cascade)
  sessionRecords SessionRecord[]

  @@map("bookings")
}

model SessionRecord {
  id             String   @id @default(cuid())
  bookingId      String   @unique
  counselorId    String
  summary        String?
  privateNotes   String?
  qualityRating  Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  counselor      Counselor @relation(fields: [counselorId], references: [id], onDelete: Cascade)

  @@map("session_records")
}

model AIConversation {
  id        String   @id @default(cuid())
  userId    String?  // Optional - for anonymous users
  messages  Json     // Array of conversation messages
  context   Json     @default("{}") // Additional context for personalization
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_conversations")
}

enum BookingStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}
